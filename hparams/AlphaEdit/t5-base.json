{
  "model_name": "google-t5/t5-base",
  "layers": [6, 7, 8, 9, 10, 11],
  "clamp_norm_factor": 0.75,
  "layer_selection": "all",
  "fact_token": "subject_last",
  "v_num_grad_steps": 20,
  "v_lr": 0.5,
  "v_loss_layer": 11,
  "v_weight_decay": 0.5,
  "kl_factor": 0.0625,
  "mom2_adjustment": true,
  "mom2_update_weight": 20000,
  "rewrite_module_tmp": "decoder.block.{}.layer.2.DenseReluDense.wo",
  "layer_module_tmp": "decoder.block.{}",
  "mlp_module_tmp": "decoder.block.{}.layer.2.DenseReluDense",
  "attn_module_tmp": "decoder.block.{}.layer.0.SelfAttention",
  "ln_f_module": "decoder.final_layer_norm",
  "lm_head_module": "lm_head",
  "mom2_dataset": "wikitext",
  "mom2_n_samples": 500,
  "mom2_dtype": "float32",
  "nullspace_threshold": 0.02,
  "L2": 10
}
